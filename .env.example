# Base URL of the apache-spark-content repo (manifest, notebooks, audio).
# Copy to `.env` and override for local dev. Defaults to the published raw URL
# when unset, so production builds need no config.

# Production (published content repo):
# VITE_CONTENT_BASE_URL=https://raw.githubusercontent.com/schemabotview/apache-spark-content/main

# Local dev (serve the sibling content repo over HTTP with CORS, e.g.
#   npx http-server ../apache-spark-content -p 8080 --cors ):
# VITE_CONTENT_BASE_URL=http://localhost:8080
